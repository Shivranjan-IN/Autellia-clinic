# Backend Environment Variables
PORT=5000
NODE_ENV=development
# Render: production

# CORS
CORS_ORIGIN=https://autellia-clinic.vercel.app,http://localhost:5173

# JWT & Session
JWT_SECRET=your-super-long-jwt-secret-change-in-prod
SESSION_SECRET=your-session-secret-change-in-prod

# Database (Render Postgres INTERNAL_URL)
DATABASE_URL="postgresql://user:pass@localhost:5432/db?schema=public"

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Supabase (if used)
SUPABASE_URL=
SUPABASE_KEY=

# Email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
